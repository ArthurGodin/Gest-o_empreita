# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Meta Ads - opcional; recomendado antes de subir campanha.
# NEXT_PUBLIC_META_PIXEL_ID=000000000000000
# META_CONVERSIONS_ACCESS_TOKEN=EAAB...
# Opcional: usar enquanto valida no Events Manager, depois remover.
# META_TEST_EVENT_CODE=TEST12345
# Opcional: sobrescreva se a Meta exigir outra versao.
# META_GRAPH_API_VERSION=v23.0

# Resend - opcional em dev; recomendado em producao.
# RESEND_API_KEY=re_xxx
# EMAIL_FROM=Gestao Empreita <contato@mail.seudominio.com.br>
# Opcional: se ausente, alertas usam o email extraido de EMAIL_FROM.
# ALERT_EMAIL_TO=voce@seudominio.com.br

# Monitoramento operacional diario - obrigatorio em producao.
# Gere pelo menos 32 bytes aleatorios e nunca exponha o valor no navegador.
# CRON_SECRET=troque-por-um-segredo-aleatorio-com-mais-de-32-caracteres

# Painel privado de saude operacional - emails separados por virgula.
# OPERATIONAL_ADMIN_EMAILS=voce@seudominio.com.br

# Asaas Pix - API key obrigatoria para criar cobrancas; webhook token obrigatorio para baixar pagamentos.
# Sandbox API: https://api-sandbox.asaas.com/v3
# Producao API: https://api.asaas.com/v3
# ASAAS_API_KEY=$aact_YOUR_KEY
# ASAAS_API_URL=https://api-sandbox.asaas.com/v3
# ASAAS_WEBHOOK_TOKEN=troque-por-um-token-forte-com-mais-de-32-caracteres
