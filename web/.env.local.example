# ─── Supabase ──────────────────────────────────────────────
# Pegue em: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Usado apenas em rotas de servidor (admin / webhooks). NUNCA exponha no client.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# ─── App ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Resend (email transacional — free tier 100/dia) ───────
# Crie em: https://resend.com → API Keys → Create
# Necessário pra notificar o empreiteiro quando cliente aprova/rejeita orçamento.
# Em dev: optional — sem a chave, notificações ficam só logadas.
# Em produção: required.
# RESEND_API_KEY=re_xxx
# Em dev, usa o domínio default 'onboarding@resend.dev' (permitido sem DNS).
# Em produção, configure seu próprio domínio no Resend.

# ─── Asaas (Pix/boleto — cobra % só sobre transação paga) ──
# Sandbox: https://sandbox.asaas.com
# ASAAS_API_KEY=
# ASAAS_API_URL=https://sandbox.asaas.com/api/v3
